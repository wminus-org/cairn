# Cairn — environment. Copy to `.env` and fill in. `.env` is gitignored.
#
# Anything prefixed EXPO_PUBLIC_ is INLINED INTO THE JS BUNDLE and is readable
# by anyone with the app. Only put values there that are designed to be public.
# Everything without that prefix is build-time only and never reaches a device.

# ---------------------------------------------------------------------------
# Supabase  —  https://supabase.com/dashboard  →  Project Settings → API
# ---------------------------------------------------------------------------

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# The `anon` / publishable key. Public by design: every table is default-deny
# under RLS and all reads go through security-definer RPCs.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# NOTE: the service_role key is NOT in this file and must never be. It bypasses
# RLS. It belongs only in the seed script's own environment (CRN-026/CRN-027),
# never in anything the app bundles.

# ---------------------------------------------------------------------------
# Mapbox  —  https://account.mapbox.com/access-tokens/
#
# TWO TOKENS. TWO DIFFERENT JOBS. THEY ARE NOT INTERCHANGEABLE.
# ---------------------------------------------------------------------------

# 1. PUBLIC token, starts `pk.`  —  RUNTIME.
#    Passed to Mapbox.setAccessToken() before the first MapView mounts.
#    Safe to ship in the bundle; that is what public tokens are for.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# 2. SECRET token, starts `sk.`, scope DOWNLOADS:READ  —  BUILD TIME ONLY.
#    CocoaPods uses it during `pod install` to fetch the Mapbox native SDK from
#    Mapbox's private registry. It has NO runtime use. It is read by
#    app.config.ts and handed to the @rnmapbox/maps config plugin.
#
#    Create it at account.mapbox.com → Create a token → tick DOWNLOADS:READ.
#    It is shown EXACTLY ONCE. Paste it here before you close that tab.
#
#    A `401 Unauthorized` during pod install means this is missing, mistyped,
#    or lacks DOWNLOADS:READ. It is never a network problem and re-running
#    does not help.
MAPBOX_DOWNLOAD_TOKEN=

# Optional: @rnmapbox/maps v10 also reads the download token from this variable
# directly, which is the non-deprecated path. Set EITHER this OR the one above.
# Setting both works but prints a deprecation warning during prebuild.
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=
